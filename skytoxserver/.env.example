# Copy this file to .env and fill your values.
# Do not commit .env or serviceAccount.json to GitHub.

PORT=8787
HOST=0.0.0.0

# true = local test mode without Firebase. false = real FCM sending.
SKYTOX_DRY_RUN=true

# Any long random string. skyTox clients must send it in X-SkyTox-Key.
SKYTOX_PUSH_API_KEY=change-this-to-a-long-random-secret

# Firebase service account JSON file path, relative to this folder or absolute.
GOOGLE_APPLICATION_CREDENTIALS=serviceAccount.json

# Optional: only allow wake-up payloads for this package.
SKYTOX_ANDROID_PACKAGE=markanddiego.skytox
